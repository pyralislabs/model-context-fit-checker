{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "ModelCatalog",
  "type": "array",
  "items": {
    "title": "ModelRecord",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "aliases",
      "displayName",
      "family",
      "parameterCount",
      "layers",
      "kvHeads",
      "headDim",
      "declaredMaxContextTokens",
      "sourceIds",
      "reviewedAt"
    ],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "aliases": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "displayName": { "type": "string", "minLength": 1 },
      "family": { "type": "string", "minLength": 1 },
      "parameterCount": { "type": "integer", "minimum": 1 },
      "layers": { "type": "integer", "minimum": 1 },
      "kvHeads": { "type": "integer", "minimum": 1 },
      "headDim": { "type": "integer", "minimum": 1 },
      "declaredMaxContextTokens": { "type": "integer", "minimum": 1 },
      "sourceIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "reviewedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
    }
  }
}
