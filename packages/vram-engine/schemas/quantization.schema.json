{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "QuantizationCatalog",
  "type": "array",
  "items": {
    "title": "QuantizationRecord",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "displayName",
      "effectiveBitsPerWeight",
      "status",
      "notes",
      "sourceIds",
      "reviewedAt"
    ],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "displayName": { "type": "string", "minLength": 1 },
      "effectiveBitsPerWeight": { "type": "number", "minimum": 0.5, "maximum": 32 },
      "status": { "type": "string", "enum": ["active", "experimental", "deprecated"] },
      "notes": { "type": "string" },
      "sourceIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
      "reviewedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
    }
  }
}
