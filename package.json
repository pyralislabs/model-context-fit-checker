  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.1.0",
    "@vitest/coverage-v8": "^3.1.0"
  }
}
